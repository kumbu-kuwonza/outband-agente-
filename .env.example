# LiveKit Server
LIVEKIT_URL=ws://your-livekit-server:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LLM (use any OpenAI-compatible provider, including free tiers)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Deepgram STT (required for voice pipeline)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cartesia TTS (required for voice pipeline)
CARTESIA_API_KEY=your_cartesia_api_key_here

# Twilio (used as SIP trunk with LiveKit)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+5511999999999

# LiveKit SIP Outbound Trunk (created via LiveKit CLI or dashboard)
SIP_OUTBOUND_TRUNK_ID=your_sip_trunk_id

# Google Sheets (contact list)
GOOGLE_SHEETS_CREDENTIALS_FILE=./credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=Contatos

# n8n Webhook (CRM/agenda integration)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/prospecting

# Campaign settings
CAMPAIGN_BATCH_SIZE=10
CAMPAIGN_DELAY_BETWEEN_CALLS=5
CAMPAIGN_COUNTRY=BR
